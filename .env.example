# qwen3-tts-streaming — server config (copy to .env)
#
# All settings are also CLI flags; env vars are the recommended way to deploy.

# --- Required -------------------------------------------------------------

# Bearer token clients must send as `Authorization: Bearer <token>`.
# Empty disables auth — do NOT do that outside localhost dev.
QWEN3_TTS_API_KEY=change-me-please

# --- Bind -----------------------------------------------------------------

QWEN3_TTS_HOST=127.0.0.1
QWEN3_TTS_PORT=8111

# --- Model ----------------------------------------------------------------

QWEN3_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base
QWEN3_TTS_DEVICE=cuda

# Reference audio for CUDA-graph warmup at boot. The repo ships
# samples/joker.wav + joker.txt as the default — no need to set these
# unless you want a different reference voice for warmup.
# QWEN3_TTS_WARMUP_REF_AUDIO=/abs/path/to/ref.wav
# QWEN3_TTS_WARMUP_REF_TEXT=Transcript of the warmup reference audio.

# --- Streaming knobs ------------------------------------------------------

# Codec tokens per yield from the model (12 = 1 second of audio).
# 8 = ~667 ms audio, TTFA ~200 ms on RTX 4090 — the demo-tested default.
QWEN3_TTS_CHUNK_SIZE=8

# Max concurrent WebSocket connections. Single GPU still serializes the model;
# cap controls how many connections can queue politely vs get server_busy.
QWEN3_TTS_CAP=4

# Max characters per `start.text`. Matches faster-qwen3-tts demo's MAX_TEXT_CHARS.
QWEN3_TTS_MAX_CHARS=1000

# LRU size for the ref-audio cache (number of distinct voices kept warm).
QWEN3_TTS_REF_CACHE_SIZE=100

# --- Timeouts (seconds) ---------------------------------------------------

# Time to wait for the `start` frame after WS accept.
QWEN3_TTS_IDLE_TIMEOUT_S=10

# Hard cap on a single synthesis. At RTF ~5 on 4090, 1000 chars ≈ 15s wall.
QWEN3_TTS_SYNTH_TIMEOUT_S=45

# --- Sampling (match faster-qwen3-tts demo defaults) ----------------------

QWEN3_TTS_TEMPERATURE=0.9
QWEN3_TTS_TOP_K=50
QWEN3_TTS_TOP_P=1.0
QWEN3_TTS_REPETITION_PENALTY=1.05
QWEN3_TTS_MAX_NEW_TOKENS=2048

# --- Logging --------------------------------------------------------------

QWEN3_TTS_LOG_LEVEL=INFO
